{
  "extends": "astro/tsconfigs/strict",
  "include": [
    ".astro/types.d.ts",
    "**/*"
  ],
  "exclude": [
    "dist"
  ],
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "verbatimModuleSyntax": false,
    "paths": {
      "@pageel/plugin-types": ["./packages/plugin-types/src/index.ts"],
      "@pageel/plugin-mdx": ["./packages/plugin-mdx/src/index.ts"],
      "@pageel/cms": ["./packages/cms-bridge/src/index.ts"]
    }
  }
}